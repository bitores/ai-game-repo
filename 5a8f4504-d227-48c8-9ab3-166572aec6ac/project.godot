[application]
config/name="光影迷宫逃脱"
config/description="在黑暗迷宫中收集宝石、躲避怪物，用闪光击败阴影！"
run/main_scene="res://scenes/title_screen.tscn"
config/icon=""
config/features=PackedStringArray("4.6")

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/size/initial_position_type=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input_devices]
pointing/emulate_touch_from_mouse=true

[physics]
common/enable_pause_aware_input=true
2d/default_gravity=0

[rendering]
renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0.04, 0.04, 0.08, 1)

[autoload]
Global="*res://scripts/global.gd"
MazeData="*res://scripts/maze_data.gd"

[input]
move_left={
"deadzone": 0.5,
"events": [{
"keycode": 65,
"type": 0
}, {
"keycode": 4194319,
"type": 0
}]
}
move_right={
"deadzone": 0.5,
"events": [{
"keycode": 68,
"type": 0
}, {
"keycode": 4194321,
"type": 0
}]
}
move_up={
"deadzone": 0.5,
"events": [{
"keycode": 87,
"type": 0
}, {
"keycode": 4194320,
"type": 0
}]
}
move_down={
"deadzone": 0.5,
"events": [{
"keycode": 83,
"type": 0
}, {
"keycode": 4194322,
"type": 0
}]
}
flash={
"deadzone": 0.5,
"events": [{
"keycode": 32,
"type": 0
}]
}
